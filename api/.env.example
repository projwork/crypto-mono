# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins (the web app dev server)
CORS_ORIGINS=http://localhost:3000

# Database (PostgreSQL + Prisma) — used in Module 1
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crypto_remittance?schema=public"

# File uploads (KYC documents) — used in Module 3
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880

# Auth (JWT) — used in Module 2
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Conversion rates (Module 14)
# CoinGecko demo API key is optional; stablecoins and ETH have prototype fallbacks.
COINGECKO_DEMO_API_KEY=
CONVERSION_RATE_CACHE_TTL_MS=60000
CONVERSION_REQUEST_TIMEOUT_MS=8000
